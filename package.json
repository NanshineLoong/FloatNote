{
  "name": "floatnote",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "shared/note-logic",
    "sidecar"
  ],
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  },
  "scripts": {
    "dev": "vite",
    "build:frontend": "tsc && vite build",
    "build:sidecar": "npm run build --workspace=floatnote-agent-sidecar",
    "build": "npm run build:frontend && npm run build:sidecar",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:frontend": "vitest run",
    "test:sidecar": "npm test --workspace=floatnote-agent-sidecar",
    "test:infra": "node --test ./scripts/*.test.mjs",
    "test": "npm run test:frontend && npm run test:infra && npm run test:sidecar",
    "smoke:sidecar": "npm run smoke --workspace=floatnote-agent-sidecar",
    "package:sidecar": "npm run package:sidecar --workspace=floatnote-agent-sidecar",
    "check": "npm run test && npm run build && npm run smoke:sidecar",
    "review:ui": "node ./scripts/review-ui.mjs",
    "review:native:doctor": "node ./scripts/native-review-doctor.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-html": "^6.4.0",
    "@codemirror/lang-javascript": "^6.2.0",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-python": "^6.1.0",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@floatnote/note-logic": "*",
    "@lezer/highlight": "^1.2.0",
    "@lezer/markdown": "^1.7.0",
    "@phosphor-icons/web": "^2.1.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "diff": "^8.0.4",
    "markdown-it": "^14.3.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@swc/core": "^1.0.0",
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.6",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "jsdom": "^27.0.1",
    "mocha": "^10.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
