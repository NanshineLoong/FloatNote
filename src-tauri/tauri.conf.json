{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FloatNote",
  "version": "0.1.0",
  "identifier": "com.floatnote.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1422",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run package:sidecar && npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 380,
        "height": 520,
        "minWidth": 360,
        "minHeight": 360,
        "visible": false,
        "alwaysOnTop": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "index.html"
      },
      {
        "label": "settings",
        "title": "",
        "width": 780,
        "height": 620,
        "minWidth": 720,
        "minHeight": 520,
        "visible": false,
        "decorations": true,
        "resizable": true,
        "maximizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "settings.html"
      },
      {
        "label": "selection-popup",
        "url": "popup.html",
        "width": 100,
        "height": 50,
        "transparent": true,
        "decorations": false,
        "focus": false,
        "focusable": true,
        "acceptFirstMouse": true,
        "alwaysOnTop": true,
        "shadow": false,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: floatnote-img:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/skills/**/*", "resources/sidecar/**/*"],
    "externalBin": ["binaries/floatnote-node"],
    "macOS": {
      "signingIdentity": "FloatNote Self Signed",
      "hardenedRuntime": true,
      "entitlements": "./Entitlements.plist"
    }
  }
}
