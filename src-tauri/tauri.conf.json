{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FloatNote",
  "version": "0.1.0",
  "identifier": "com.floatnote.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1422",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 380,
        "height": 520,
        "minWidth": 360,
        "minHeight": 360,
        "visible": false,
        "alwaysOnTop": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "index.html"
      },
      {
        "label": "settings",
        "title": "FloatNote 设置",
        "width": 420,
        "height": 500,
        "minHeight": 400,
        "visible": false,
        "url": "settings.html"
      },
      {
        "label": "selection-popup",
        "url": "popup.html",
        "width": 256,
        "height": 46,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "FloatNote Self Signed"
    }
  }
}
